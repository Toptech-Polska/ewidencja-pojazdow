# ============================================================
# EwidencjaVAT — Zmienne srodowiskowe
# ============================================================
# KROK 1: Skopiuj ten plik: cp .env.local.example .env.local
# KROK 2: Uzupelnij wartosci ponizej
#
# Gdzie znalezc klucze Supabase:
#   -> https://supabase.com/dashboard/project/cukohoqgvcsvmopvivjt/settings/api
#   -> "Project URL" -> NEXT_PUBLIC_SUPABASE_URL
#   -> "anon public" -> NEXT_PUBLIC_SUPABASE_ANON_KEY
#   -> "service_role" -> SUPABASE_SERVICE_ROLE_KEY (tylko backend!)
# ============================================================

# Supabase — wymagane
NEXT_PUBLIC_SUPABASE_URL=https://cukohoqgvcsvmopvivjt.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=WSTAW_KLUCZ_ANON_Z_DASHBOARDU_SUPABASE

# Supabase — tylko na serwerze (NIE NEXT_PUBLIC_!)
# Uzywany tylko w route handlers / server actions
SUPABASE_SERVICE_ROLE_KEY=WSTAW_KLUCZ_SERVICE_ROLE_Z_DASHBOARDU_SUPABASE

# Aplikacja
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_COMPANY_NAME=Toptech Polska Sp. z o.o.
NEXT_PUBLIC_COMPANY_NIP=953-000-11-22

# Google Maps — tylko server-side (NIE NEXT_PUBLIC_!)
# Wymagane API: Distance Matrix API + Places API (Autocomplete)
# Gdzie znalezc: https://console.cloud.google.com/apis/credentials
# Ogranicz klucz do: Distance Matrix API + Places API + HTTP referrers (Twoja domena)
GOOGLE_MAPS_API_KEY=WSTAW_KLUCZ_Z_GOOGLE_CLOUD_CONSOLE
